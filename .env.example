# ─── Supabase ─────────────────────────────────────────────────────────────────
# Copy your project URL and anon key from: supabase.com → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Publishable key — safe for frontend (VITE_ prefix exposes it to browser)
# Find at: dashboard.stripe.com → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Secret key — SERVER ONLY. No VITE_ prefix = never sent to browser.
# Used by api/create-payment-intent.js (Vercel serverless) and Vite dev middleware.
# Find at: dashboard.stripe.com → Developers → API keys
# On Vercel: add this in Project → Settings → Environment Variables
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_URL=http://localhost:5174
